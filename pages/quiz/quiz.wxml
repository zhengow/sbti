<view class="container">
  <view class="card quiz-wrap">
    <view class="topbar">
      <view class="progress">
        <view class="progress-inner" style="width: {{progressPercent}}%;"></view>
      </view>
      <view class="progress-text">{{doneCount}} / {{totalCount}}</view>
    </view>

    <view class="meta-row">
      <view class="eta">预计剩余约 {{etaMinutes}} 分钟</view>
      <view class="quit" bindtap="goHome">退出测试</view>
    </view>

    <view class="hint">{{hintText}}</view>

    <view class="question-card" wx:if="{{currentQuestion}}">
      <view class="q-meta">
        <view class="badge">第 {{currentIndex + 1}} 题</view>
        <view class="dim">{{currentQuestion.special ? '补充题' : '维度已隐藏'}}</view>
      </view>

      <view class="q-title">{{currentQuestion.text}}</view>

      <view class="options">
        <block wx:for="{{currentQuestion.options}}" wx:for-item="option" wx:for-index="optIndex" wx:key="value">
          <view class="opt {{answers[currentQuestion.id] === option.value ? 'opt-active' : ''}}"
            data-qid="{{currentQuestion.id}}"
            data-value="{{option.value}}"
            bindtap="onSelect">
            <view class="opt-code">{{letters[optIndex]}}</view>
            <view class="opt-label">{{option.label}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="footer-tip">{{footerTip}}</view>

    <view class="actions">
      <button class="secondary-btn btn" disabled="{{!canPrev}}" bindtap="onPrev">上一题</button>
    </view>
  </view>
</view>
