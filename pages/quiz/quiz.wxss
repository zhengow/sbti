.quiz-wrap {
  padding: 24rpx;
  margin-top: 10rpx;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e7efe9;
}

.progress-inner {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #95b49c, #5b7862);
  transition: width 0.25s ease;
}

.progress-text {
  color: #66746c;
  font-size: 24rpx;
  min-width: 110rpx;
  text-align: right;
}

.meta-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eta {
  color: #65736b;
  font-size: 23rpx;
}

.quit {
  color: #4f6a56;
  font-size: 23rpx;
  text-decoration: underline;
}

.hint {
  margin-top: 14rpx;
  background: #eff6f0;
  border: 1rpx solid #d8e5da;
  border-radius: 14rpx;
  color: #55705d;
  font-size: 24rpx;
  line-height: 1.7;
  padding: 14rpx 16rpx;
}

.question-card {
  margin-top: 14rpx;
  border: 1rpx solid #d8e5da;
  border-radius: 20rpx;
  padding: 20rpx;
  background: linear-gradient(180deg, #ffffff, #f9fcfa);
}

.q-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.badge,
.dim {
  font-size: 22rpx;
  color: #6a776f;
  padding: 6rpx 12rpx;
  border: 1rpx solid #d8e5da;
  border-radius: 999rpx;
  background: #eef5ef;
}

.q-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  line-height: 1.68;
  color: #263229;
}

.options {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.opt {
  border: 1rpx solid #d8e5da;
  border-radius: 16rpx;
  background: #fff;
  display: flex;
  gap: 14rpx;
  padding: 18rpx 16rpx;
  transition: all 0.15s ease;
}

.opt-active {
  border-color: #64846c;
  background: #f2f8f3;
}

.opt-code {
  width: 40rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #4b6651;
  flex-shrink: 0;
}

.opt-label {
  flex: 1;
  font-size: 27rpx;
  color: #2d3a30;
  line-height: 1.66;
}

.footer-tip {
  margin-top: 16rpx;
  color: #5f6f65;
  font-size: 24rpx;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  height: 84rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  font-size: 28rpx;
}
