.hero {
  padding: 42rpx 34rpx;
  margin-top: 24rpx;
  position: relative;
}

.tag {
  position: relative;
  z-index: 1;
  display: inline-block;
  background: #edf5ef;
  color: #4a6652;
  border: 1rpx solid #d8e5da;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 10rpx 18rpx;
}

.title {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  font-size: 58rpx;
  line-height: 1.16;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.sub {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  color: #627168;
  line-height: 1.8;
  font-size: 28rpx;
}

.start-btn {
  margin-top: 36rpx;
  height: 88rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  font-size: 30rpx;
}

.meta {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  color: #6a776f;
  font-size: 24rpx;
  line-height: 1.8;
  text-align: center;
}
