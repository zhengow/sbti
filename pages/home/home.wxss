.hero {
  padding: 42rpx 34rpx;
  margin-top: 24rpx;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: "";
  position: absolute;
  right: -88rpx;
  top: -86rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(102, 134, 111, 0.18), rgba(102, 134, 111, 0));
}

.tag {
  position: relative;
  z-index: 1;
  display: inline-block;
  background: #edf5ef;
  color: #4a6652;
  border: 1rpx solid #d8e5da;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 10rpx 18rpx;
}

.title {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  font-size: 58rpx;
  line-height: 1.16;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.sub {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  color: #627168;
  line-height: 1.8;
  font-size: 28rpx;
}

.start-btn {
  margin-top: 36rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.meta {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  color: #6a776f;
  font-size: 24rpx;
  line-height: 1.8;
}
